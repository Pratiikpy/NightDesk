# Secrets — never commit
.env
.env.*
!.env.example

# Dependencies / build
node_modules/
dist/
__pycache__/
*.pyc
*.tar.gz

# Data: ignore everything under the top-level data/ EXCEPT the recordings + research that
# judges need to reproduce results. The signing key (data/ledger/) is never un-ignored.
# Root-anchored with /data/* so it never touches src/data/.
/data/*
!/data/snapshots/
!/data/research/
!/data/fixtures/
!/data/skillhub/
/recordings/

# Logs
*.log
logs/

# Local research clones / reference repos
.research/

# Internal strategy / self-assessment docs — keep local, never ship to the judge-facing tree
win-strategy.md
judge-eval.md

